{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mosaic.mair.com/schema/mosaic.json",
  "title": "MOSAIC Catalog Schema",
  "type": "array",
  "items": {
    "$ref": "#/$defs/project"
  },
  "$defs": {
    "dateString": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "url",
        "platform",
        "type",
        "domain",
        "tags",
        "affiliations",
        "sub_affiliations",
        "language",
        "license",
        "doi",
        "status",
        "created_at"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 20
        },
        "url": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          },
          "uniqueItems": true
        },
        "platform": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "type": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "domain": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "affiliations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sub_affiliations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "language": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "license": {
          "type": [
            "string",
            "null"
          ]
        },
        "doi": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "$ref": "#/$defs/dateString"
        }
      }
    }
  }
}
